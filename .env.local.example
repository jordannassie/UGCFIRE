# Supabase - get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://yawgvntvhpgittvntihx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here
# Optional: override auth cookie/storage key used by @supabase/ssr for PKCE/session.
# NEXT_PUBLIC_SUPABASE_AUTH_COOKIE_NAME=ugcfire-auth
# Backward-compatible fallback also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server only. Needed for profile sync, admin allowlist checks, and Netlify runtime auth completion.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Optional server-side bootstrap allowlist, comma-separated.
# Also keep the Supabase admin_allowed_emails table in sync for DB-trigger assignment.
UGCFIRE_ADMIN_EMAILS=your-email-here
